<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TheEndOfMine.Views.DifficultyPage"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False">
    <Grid>
        <!-- 1. รูปพื้นหลังหลัก -->
        <Image Source="story/ui/ui_difficulty_select.png" Aspect="AspectFill" />

        <!-- 2. เลเยอร์ปุ่มล่องหนสำหรับเลือกความยาก -->
        <AbsoluteLayout>

            <!-- กรอบทอง EASY -->
            <Border x:Name="GlowEasy"
                    Stroke="#fef1ab" StrokeThickness="7"
                    BackgroundColor="Transparent" Opacity="0"
                    AbsoluteLayout.LayoutBounds="0.5, 0.397, 291, 64"
                    AbsoluteLayout.LayoutFlags="PositionProportional">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="7"/>
                </Border.StrokeShape>
            </Border>

            <!-- กรอบทอง NORMAL -->
            <Border x:Name="GlowNormal"
                    Stroke="#fef1ab" StrokeThickness="7"
                    BackgroundColor="Transparent" Opacity="0"
                    AbsoluteLayout.LayoutBounds="0.5, 0.577, 291, 64"
                    AbsoluteLayout.LayoutFlags="PositionProportional">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="7"/>
                </Border.StrokeShape>
            </Border>

            <!-- กรอบทอง HARD -->
            <Border x:Name="GlowHard"
                    Stroke="#fef1ab" StrokeThickness="7"
                    BackgroundColor="Transparent" Opacity="0"
                    AbsoluteLayout.LayoutBounds="0.5, 0.753, 290, 64"
                    AbsoluteLayout.LayoutFlags="PositionProportional">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="7"/>
                </Border.StrokeShape>
            </Border>

            <!-- ปุ่ม EASY -->
            <Button BackgroundColor="Transparent"
                    Clicked="OnEasyTapped"
                    AbsoluteLayout.LayoutBounds="0.5, 0.398, 280, 57"
                    AbsoluteLayout.LayoutFlags="PositionProportional" />

            <!-- ปุ่ม NORMAL -->
            <Button BackgroundColor="Transparent"
                    Clicked="OnNormalTapped"
                    AbsoluteLayout.LayoutBounds="0.5, 0.575, 280, 57"
                    AbsoluteLayout.LayoutFlags="PositionProportional" />

            <!-- ปุ่ม HARD -->
            <Button BackgroundColor="Transparent"
                    Clicked="OnHardTapped"
                    AbsoluteLayout.LayoutBounds="0.5, 0.750, 280, 57"
                    AbsoluteLayout.LayoutFlags="PositionProportional" />

            <!-- ปุ่ม Confirm ซ่อนไว้ก่อน -->
            <Image x:Name="ConfirmBtn"
                   Source="story/ui/ui_confirm_button.png"
                   IsVisible="False"
                   WidthRequest="300" HeightRequest="80"
                   Aspect="AspectFit"
                   AbsoluteLayout.LayoutBounds="0.5, 0.95, 280, 80"
                   AbsoluteLayout.LayoutFlags="PositionProportional">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnConfirmTapped"/>
                </Image.GestureRecognizers>
            </Image>

        </AbsoluteLayout>
    </Grid>
</ContentPage>
