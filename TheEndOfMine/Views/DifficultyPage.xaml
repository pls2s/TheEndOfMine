<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TheEndOfMine.Views.DifficultyPage"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">
    <Grid>
        <!-- 1. รูปพื้นหลังหลัก -->
        <Image Source="story/female/female_difficulty_select.png" Aspect="AspectFill" />

        <!-- 2. เลเยอร์ปุ่มล่องหนสำหรับเลือกความยาก -->
        <AbsoluteLayout x:Name="DifficultyOverlay">

            <!-- กรอบทอง EASY -->
            <Border x:Name="GlowEasy"
                    Stroke="#fef1ab" StrokeThickness="4"
                    BackgroundColor="Transparent" Opacity="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="5"/>
                </Border.StrokeShape>
            </Border>

            <!-- กรอบทอง NORMAL -->
            <Border x:Name="GlowNormal"
                    Stroke="#fef1ab" StrokeThickness="4"
                    BackgroundColor="Transparent" Opacity="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="5"/>
                </Border.StrokeShape>
            </Border>

            <!-- กรอบทอง HARD -->
            <Border x:Name="GlowHard"
                    Stroke="#fef1ab" StrokeThickness="4"
                    BackgroundColor="Transparent" Opacity="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="5"/>
                </Border.StrokeShape>
            </Border>

            <!-- ปุ่ม EASY -->
            <Button x:Name="EasyButton"
                    BackgroundColor="Transparent"
                    Clicked="OnEasyTapped" />

            <!-- ปุ่ม NORMAL -->
            <Button x:Name="NormalButton"
                    BackgroundColor="Transparent"
                    Clicked="OnNormalTapped" />

            <!-- ปุ่ม HARD -->
            <Button x:Name="HardButton"
                    BackgroundColor="Transparent"
                    Clicked="OnHardTapped" />

            <!-- ปุ่ม Confirm ซ่อนไว้ก่อน -->
            <Image x:Name="ConfirmBtn"
                   Source="story/female/female_confirm_button.png"
                   IsVisible="False"
                   Aspect="AspectFit">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnConfirmTapped"/>
                </Image.GestureRecognizers>
            </Image>

        </AbsoluteLayout>
    </Grid>
</ContentPage>
