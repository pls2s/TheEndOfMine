<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TheEndOfMine.Views.IntroPage"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <!-- 1. เลเยอร์เกมหลัก (สว่างรอไว้เลย) -->
        <Grid x:Name="GameLayer">
            <!-- ตั้งรูปตั้งต้นเป็นผู้หญิง (ตรวจสอบชื่อไฟล์ให้ตรงกับในเครื่อง) -->
            <Image x:Name="BackgroundImage" 
               Source="story/female/female_select_char.png"  
               Aspect="AspectFill" />

            <!-- เลเยอร์ภาพทับสำหรับ crossfade ตอนสลับตัวละคร -->
            <Image x:Name="TransitionImage"
                   Source="story/female/female_select_char.png"
                   Aspect="AspectFill"
                   Opacity="0"
                   InputTransparent="True" />
            <AbsoluteLayout x:Name="SelectionUI">
                <!-- ปุ่มเลือกชาย -->
                <ImageButton x:Name="MaleButton" 
                         BackgroundColor="Transparent"
                         AbsoluteLayout.LayoutBounds="0.205, 0.68, 125, 127"
                         AbsoluteLayout.LayoutFlags="PositionProportional"
                         Clicked="OnMaleClicked" />

                <!-- ปุ่มเลือกหญิง -->
                <ImageButton x:Name="FemaleButton" 
                         BackgroundColor="Transparent"
                         AbsoluteLayout.LayoutBounds="0.79, 0.685, 125, 127"
                         AbsoluteLayout.LayoutFlags="PositionProportional"
                         Clicked="OnFemaleClicked" />

                <!-- ช่องใส่ชื่อ -->
                <Entry x:Name="NameEntry" 
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   BackgroundColor="Transparent"
                   FontSize="25"
                   MaxLength="8"
                   AbsoluteLayout.LayoutBounds="0.5, 0.839, 300, 50"
                   AbsoluteLayout.LayoutFlags="PositionProportional" />

                <!-- ปุ่มเริ่มเกม -->
                <Button x:Name="StartButton" 
                    BackgroundColor="Transparent"
                    AbsoluteLayout.LayoutBounds="0.5, 0.95, 280, 65"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    Clicked="OnStartClicked" />
            </AbsoluteLayout>
        </Grid>

        <!-- 2. หน้าปก Loading -->
        <Grid x:Name="TitleLayer" BackgroundColor="Black">
            <Image Source="splash_page.png"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill"
                   InputTransparent="True" />
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#33000000" Offset="0" />
                        <GradientStop Color="#22000000" Offset="0.58" />
                        <GradientStop Color="#AA000000" Offset="1" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Label x:Name="TapToStartLabel" Text="— TAP TO START —" TextColor="White" HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,100" />
            <Button BackgroundColor="Transparent" HorizontalOptions="Fill" VerticalOptions="Fill" Clicked="OnTapToStartClicked" />
        </Grid>

        <!-- 3. Loading หลังปุ่ม START -->
        <Grid x:Name="StartLoadingOverlay"
              BackgroundColor="#050505"
              IsVisible="False"
              Opacity="0"
              ZIndex="20">
            <Image x:Name="StartLoadingImage"
                   Source="story/chapter/chapter_ruined_city_sunset.png"
                   Aspect="AspectFill"
                   Opacity="0.72" />

            <BoxView>
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#77000000" Offset="0" />
                        <GradientStop Color="#CC000000" Offset="0.58" />
                        <GradientStop Color="#F8000000" Offset="1" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <VerticalStackLayout Padding="28"
                                 Spacing="14"
                                 VerticalOptions="End"
                                 Margin="0,0,0,46">
                <Label x:Name="StartLoadingTitleLabel"
                       Text="กำลังสร้างโลก"
                       TextColor="#D8B45F"
                       FontSize="26"
                       FontAttributes="Bold" />

                <Label x:Name="StartLoadingDetailLabel"
                       Text="กำลังเตรียมบทแรก"
                       TextColor="#EFE8D8"
                       FontSize="14"
                       LineBreakMode="WordWrap" />

                <ProgressBar x:Name="StartLoadingProgress"
                             Progress="0"
                             ProgressColor="#D8B45F"
                             BackgroundColor="#443E34" />

                <Label x:Name="StartLoadingPercentLabel"
                       Text="0%"
                       TextColor="#AFA694"
                       FontSize="12"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>
        </Grid>

        <!-- 4. Custom game alert -->
        <Grid x:Name="GameAlertOverlay"
              IsVisible="False"
              InputTransparent="True"
              Opacity="0"
              BackgroundColor="#CC000000"
              Padding="26"
              ZIndex="80">
            <Border Padding="20"
                    WidthRequest="330"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="#151310"
                    Stroke="#D8B45F"
                    StrokeThickness="1.5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                    <Label x:Name="GameAlertTitleLabel"
                           Text="แจ้งเตือน"
                           TextColor="#D8B45F"
                           FontSize="20"
                           FontAttributes="Bold"
                           CharacterSpacing="0.5" />

                    <Label Grid.Row="1"
                           x:Name="GameAlertMessageLabel"
                           TextColor="#EFE8D8"
                           FontSize="14"
                           LineBreakMode="WordWrap"
                           LineHeight="1.25" />

                    <Button Grid.Row="2"
                            x:Name="GameAlertOkButton"
                            Text="ตกลง"
                            Clicked="OnGameAlertOkClicked"
                            BackgroundColor="#D8B45F"
                            TextColor="#111111"
                            FontAttributes="Bold"
                            CornerRadius="7"
                            Padding="14,10" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
