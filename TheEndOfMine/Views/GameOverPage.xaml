<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TheEndOfMine.Views.GameOverPage"
             BackgroundColor="#050505"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">
    <Grid Padding="24">
        <VerticalStackLayout Spacing="18"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">
            <Label Text="THE END OF MINE"
                   TextColor="#D8B45F"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <Border x:Name="EndingImageFrame"
                    IsVisible="False"
                    Stroke="#5C503A"
                    StrokeThickness="1"
                    BackgroundColor="#10100E"
                    WidthRequest="360"
                    HeightRequest="245">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Image x:Name="EndingImage"
                       Aspect="AspectFill" />
            </Border>

            <Label x:Name="ResultTitleLabel"
                   Text="การเดินทางครั้งนี้จบลงแล้ว"
                   TextColor="#EFE8D8"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <Border x:Name="CauseFrame"
                    Stroke="#4E493F"
                    StrokeThickness="1"
                    BackgroundColor="#141210"
                    Padding="16"
                    WidthRequest="360">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="CauseTitleLabel"
                           Text="สาเหตุ"
                           TextColor="#D8B45F"
                           FontSize="13"
                           FontAttributes="Bold" />
                    <Label x:Name="CauseLabel"
                           Text="กำลังสรุปเหตุการณ์สุดท้าย"
                           TextColor="#EFE8D8"
                           FontSize="14"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="DeathDetailLabel"
                   Text="ถ้าต้องการเริ่มใหม่ ให้กลับไปเลือกตัวละครอีกครั้ง"
                   TextColor="#AFA694"
                   FontSize="13"
                   HorizontalTextAlignment="Center" />

            <Button x:Name="RespawnButton"
                    Text="กลับไปเริ่มวันนั้น"
                    Clicked="OnRespawnClicked"
                    IsVisible="False"
                    BackgroundColor="#D8B45F"
                    TextColor="#111111"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Padding="16,12" />

            <Button x:Name="HomeButton"
                    Text="กลับหน้าเริ่มเกม"
                    Clicked="OnHomeClicked"
                    BackgroundColor="#191715"
                    BorderColor="#4E493F"
                    BorderWidth="1"
                    TextColor="#EFE8D8"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    WidthRequest="360"
                    Padding="16,12" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
