<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TheEndOfMine.Views.InventoryPage"
             BackgroundColor="#080807"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto" Padding="18,18,18,22" RowSpacing="14">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <Button Text="‹"
                    Clicked="OnBackClicked"
                    WidthRequest="44"
                    HeightRequest="44"
                    BackgroundColor="#191715"
                    BorderColor="#4E493F"
                    BorderWidth="1"
                    TextColor="#EDE3D1"
                    FontSize="26"
                    CornerRadius="6" />

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                <Label Text="INVENTORY"
                       TextColor="#D8B45F"
                       FontSize="18"
                       FontAttributes="Bold"
                       CharacterSpacing="1" />
                <Label x:Name="CapacityLabel"
                       TextColor="#AFA694"
                       FontSize="12" />
            </VerticalStackLayout>

            <Label Grid.Column="2"
                   x:Name="WeightLabel"
                   VerticalOptions="Center"
                   TextColor="#AFA694"
                   FontSize="12"
                   HorizontalTextAlignment="End" />
        </Grid>

        <CollectionView Grid.Row="1"
                        x:Name="InventoryGrid"
                        SelectionMode="Single"
                        SelectionChanged="OnSlotSelected">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="4"
                                 HorizontalItemSpacing="8"
                                 VerticalItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="7"
                            HeightRequest="78"
                            BackgroundColor="#171512"
                            Stroke="#443E34"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6" />
                        </Border.StrokeShape>

                        <Grid>
                        <Image Source="{Binding ImageSource}"
                               Aspect="AspectFit"
                               IsVisible="{Binding HasItem}" />

                        <Label Text="{Binding EmptyText}"
                               IsVisible="{Binding IsEmpty}"
                               TextColor="#4E493F"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />

                        <Label Text="{Binding ShortName}"
                               IsVisible="{Binding HasItem}"
                               TextColor="#EFE8D8"
                               FontSize="10"
                               LineBreakMode="TailTruncation"
                               BackgroundColor="#99000000"
                               Padding="4,2"
                               VerticalOptions="End"
                               HorizontalTextAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="2"
                Padding="14"
                BackgroundColor="#151310"
                Stroke="#443E34"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="6" />
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
            <Label x:Name="ItemNameLabel"
                   Text="เลือกไอเทมเพื่อดูรายละเอียด"
                   TextColor="#F2E9D8"
                   FontSize="16"
                   FontAttributes="Bold"
                   LineBreakMode="WordWrap" />

            <Label Grid.Row="1"
                   x:Name="ItemMetaLabel"
                   TextColor="#D8B45F"
                   FontSize="12"
                   LineBreakMode="WordWrap" />

            <Label Grid.Row="2"
                   x:Name="ItemDescriptionLabel"
                   TextColor="#BEB6A5"
                   FontSize="13"
                   LineHeight="1.2"
                   LineBreakMode="WordWrap" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
