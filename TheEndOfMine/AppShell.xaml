<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TheEndOfMine.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TheEndOfMine.Views"
    xmlns:local="clr-namespace:TheEndOfMine"
    Title="TheEndOfMine">

    <!-- Start with IntroPage as the initial page -->
    <ShellContent Title="Intro" ContentTemplate="{DataTemplate views:IntroPage}" Route="intro" />
    <ShellContent Title="Difficulty" ContentTemplate="{DataTemplate views:DifficultyPage}" Route="difficulty" />
    <ShellContent Title="Main" ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />

</Shell>
