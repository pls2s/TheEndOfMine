<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TheEndOfMine.MainPage"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <!-- Outermost Grid (ไม่มี Padding) -->
    <Grid>

        <!-- ================= 1. เลเยอร์ล่างสุด: WebView เล่นวิดีโอ ================= -->
        <WebView x:Name="BgWebView" 
                 HorizontalOptions="Fill" 
                 VerticalOptions="Fill" 
                 InputTransparent="True" />

        <!-- ================= 2. เลเยอร์ UI หลัก (มี Padding ขอบจอ) ================= -->
        <Grid Padding="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ส่วนบน: Status & Inventory -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                <Frame Grid.Column="0" BackgroundColor="#88000000" BorderColor="#555555" Padding="10" CornerRadius="5" HorizontalOptions="Start">
                    <VerticalStackLayout Spacing="6" WidthRequest="168">
                        <Grid ColumnDefinitions="44, *" ColumnSpacing="8">
                            <Image Source="story/ui/ui_hp_icon.png" WidthRequest="42" HeightRequest="28" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="Transparent" />
                            <ProgressBar Grid.Column="1" Progress="{Binding HPProgress}" ProgressColor="#CC3333" BackgroundColor="#333333" />
                        </Grid>
                        <Grid ColumnDefinitions="44, *" ColumnSpacing="8">
                            <Image Source="story/ui/ui_food_icon.png" WidthRequest="42" HeightRequest="28" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="Transparent" />
                            <ProgressBar Grid.Column="1" Progress="{Binding HungerProgress}" ProgressColor="#D4A017" BackgroundColor="#333333" />
                        </Grid>
                        <Grid ColumnDefinitions="44, *" ColumnSpacing="8">
                            <Image Source="story/ui/ui_water_icon.png" WidthRequest="42" HeightRequest="28" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="Transparent" />
                            <ProgressBar Grid.Column="1" Progress="{Binding ThirstProgress}" ProgressColor="#3399CC" BackgroundColor="#333333" />
                        </Grid>
                        <Grid ColumnDefinitions="44, *" ColumnSpacing="8">
                            <Image Source="story/ui/ui_stamina_icon.png" WidthRequest="42" HeightRequest="28" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="Transparent" />
                            <ProgressBar Grid.Column="1" Progress="{Binding FatigueProgress}" ProgressColor="#888888" BackgroundColor="#333333" />
                        </Grid>
                        <Grid ColumnDefinitions="44, *" ColumnSpacing="8">
                            <Label Text="!" FontSize="22" TextColor="#E67E22" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                            <ProgressBar Grid.Column="1" Progress="{Binding NoiseProgress}" ProgressColor="#E67E22" BackgroundColor="#333333" />
                        </Grid>
                        <Grid ColumnDefinitions="44, *" ColumnSpacing="8">
                            <Label Text="+" FontSize="22" TextColor="#8F6AD8" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                            <ProgressBar Grid.Column="1" Progress="{Binding InfectionProgress}" ProgressColor="#8F6AD8" BackgroundColor="#333333" />
                        </Grid>
                        <Label Text="{Binding SurvivalPressureDisplay}" TextColor="#AFA694" FontSize="10" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="End">
                    <ImageButton Source="story/ui/ui_inventory_button.png"
                                 WidthRequest="60"
                                 HeightRequest="60"
                                 BackgroundColor="Transparent"
                                 Clicked="OnInventoryClicked" />
                    <Label Text="INVENTORY" TextColor="White" FontSize="10" HorizontalOptions="Center" />

                    <Button Text="☰"
                            Clicked="OnGameMenuClicked"
                            WidthRequest="46"
                            HeightRequest="38"
                            Margin="0,8,0,0"
                            BackgroundColor="#AA191715"
                            BorderColor="#D8B45F"
                            BorderWidth="1"
                            TextColor="#EFE8D8"
                            FontSize="20"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            Padding="0" />
                </VerticalStackLayout>
            </Grid>

            <Border x:Name="GameMenuPanel"
                    Grid.Row="0"
                    IsVisible="False"
                    Opacity="0"
                    TranslationY="-8"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,106,0,0"
                    Padding="10"
                    BackgroundColor="#EE151310"
                    Stroke="#D8B45F"
                    StrokeThickness="1.2"
                    ZIndex="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="8" WidthRequest="118">
                    <Button Text="{Binding StopButtonText}"
                            Clicked="OnStopClicked"
                            BackgroundColor="#241F19"
                            BorderColor="#4E493F"
                            BorderWidth="1"
                            TextColor="#EFE8D8"
                            FontSize="12"
                            FontAttributes="Bold"
                            CornerRadius="7"
                            Padding="10,8" />

                    <Button x:Name="SaveGameButton"
                            Text="SAVE GAME"
                            Clicked="OnSaveGameClicked"
                            BackgroundColor="#D8B45F"
                            TextColor="#111111"
                            FontSize="11"
                            FontAttributes="Bold"
                            CornerRadius="7"
                            Padding="10,8" />

                    <Button x:Name="SoundToggleButton"
                            Text="SOUND ON"
                            Clicked="OnSoundToggleClicked"
                            BackgroundColor="#241F19"
                            BorderColor="#4E493F"
                            BorderWidth="1"
                            TextColor="#EFE8D8"
                            FontSize="11"
                            FontAttributes="Bold"
                            CornerRadius="7"
                            Padding="10,8" />
                </VerticalStackLayout>
            </Border>

            <!-- ส่วนกลาง: ปุ่มบนฉาก (ประตู / เตียง) -->
            <AbsoluteLayout Grid.Row="1" HorizontalOptions="Fill" VerticalOptions="Fill">
                <Button Text="{Binding GoOutsideButtonText}"
                    Command="{Binding GoOutsideCommand}"
                    Clicked="OnGoOutsideClicked"
                    AbsoluteLayout.LayoutBounds="0.0001, 0.4, 110, 45"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    BackgroundColor="#88000000" TextColor="White" BorderColor="Gray" BorderWidth="1" CornerRadius="5" />

                <!-- ===== เปลี่ยนกลุ่มปุ่ม REST ใหม่ ===== -->
                <VerticalStackLayout AbsoluteLayout.LayoutBounds="1, 0.6, 100, AutoSize"
                         AbsoluteLayout.LayoutFlags="PositionProportional"
                         Spacing="5">

                    <!-- ใช้ Frame ครอบ Label เพื่อสร้างกล่องที่มีขอบและพื้นหลัง -->
                    <Frame BackgroundColor="#88000000" 
               BorderColor="Gray" 
               CornerRadius="5" 
               Padding="0,8" 
               HasShadow="False">

                        <Label Text="REST / SLEEP" 
                   TextColor="LightGray" 
                   HorizontalOptions="Center" 
                   FontAttributes="Bold"/>
                    </Frame>

                    <Button x:Name="Btn4H" Text="4 HOURS" 
                BackgroundColor="#88000000" TextColor="White" BorderColor="Gray" BorderWidth="1" CornerRadius="5"
                Clicked="OnRest4HClicked"/>

                    <Button x:Name="Btn8H" Text="8 HOURS" 
                BackgroundColor="#88000000" TextColor="White" BorderColor="Gray" BorderWidth="1" CornerRadius="5"
                Clicked="OnRest8HClicked"/>

                </VerticalStackLayout>
            </AbsoluteLayout>

            <!-- ส่วนล่าง: Skills & Time -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto, *">
                <Frame Grid.Column="0" BackgroundColor="#88000000" BorderColor="#555555" Padding="10" CornerRadius="5">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="SKILLS" TextColor="#D4A017" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="🗡 Melee EXP" TextColor="LightGray" FontSize="12" />
                        <Label Text="🔍 Scavenge EXP" TextColor="LightGray" FontSize="12" />
                        <Label Text="💧 Wioating EXP" TextColor="LightGray" FontSize="12" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" BackgroundColor="#88000000" BorderColor="#555555" Padding="10" CornerRadius="5" Margin="10,0,0,0">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="{Binding DayTimeDisplay}" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="(1 real second = 1 game minute)" TextColor="Gray" FontSize="10" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Grid>
        <!-- จบเลเยอร์ UI หลัก -->

        <!-- ================= 3. Chapter Loading Overlay ================= -->
        <Grid x:Name="LoadingOverlay"
              BackgroundColor="#050505"
              IsVisible="True"
              ZIndex="999">
            <Image x:Name="LoadingChapterImage"
                   Source="story/chapter/chapter_ruined_city_sunset.png"
                   Aspect="AspectFill"
                   Opacity="0.72" />

            <BoxView>
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#77000000" Offset="0" />
                        <GradientStop Color="#CC000000" Offset="0.56" />
                        <GradientStop Color="#FA000000" Offset="1" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <VerticalStackLayout Padding="28"
                                 Spacing="14"
                                 VerticalOptions="End"
                                 Margin="0,0,0,46">
                <Label x:Name="LoadingTitleLabel"
                       Text="ENTERING CHAPTER"
                       TextColor="#D8B45F"
                       FontSize="13"
                       FontAttributes="Bold"
                       CharacterSpacing="1.5" />

                <Label x:Name="LoadingChapterLabel"
                       Text="กำลังโหลดฉาก"
                       TextColor="#EFE8D8"
                       FontSize="25"
                       FontAttributes="Bold"
                       LineBreakMode="WordWrap" />

                <Label x:Name="LoadingDetailLabel"
                       Text="กำลังเตรียมข้อมูลเกม"
                       TextColor="#AFA694"
                       FontSize="13"
                       LineBreakMode="WordWrap" />

                <ProgressBar x:Name="LoadingProgress"
                             Progress="0"
                             ProgressColor="#D8B45F"
                             BackgroundColor="#443E34" />

                <Label x:Name="LoadingPercentLabel"
                       Text="0%"
                       TextColor="#AFA694"
                       FontSize="12"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>
        </Grid>

        <!-- ================= 4. Chapter Transition Overlay ================= -->
        <Grid IsVisible="{Binding IsChapterLoading}"
              BackgroundColor="#050505"
              ZIndex="1000">
            <Image Source="{Binding ChapterLoadingImage}"
                   Aspect="AspectFill"
                   Opacity="0.74" />

            <BoxView>
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#66000000" Offset="0" />
                        <GradientStop Color="#C9000000" Offset="0.52" />
                        <GradientStop Color="#FB000000" Offset="1" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <VerticalStackLayout Padding="28"
                                 Spacing="14"
                                 VerticalOptions="End"
                                 Margin="0,0,0,46">
                <Label Text="{Binding ChapterLoadingTitle}"
                       TextColor="#D8B45F"
                       FontSize="13"
                       FontAttributes="Bold"
                       CharacterSpacing="1.5" />

                <Label Text="{Binding ChapterLoadingDetail}"
                       TextColor="#EFE8D8"
                       FontSize="25"
                       FontAttributes="Bold"
                       LineBreakMode="WordWrap" />

                <ProgressBar Progress="{Binding ChapterLoadingProgress}"
                             ProgressColor="#D8B45F"
                             BackgroundColor="#443E34" />

                <Label Text="{Binding ChapterLoadingPercentText}"
                       TextColor="#AFA694"
                       FontSize="12"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>
        </Grid>

        <!-- ================= 5. First-time Tutorial Overlay ================= -->
        <Grid x:Name="TutorialOverlay"
              IsVisible="False"
              Opacity="0"
              BackgroundColor="#DD000000"
              Padding="24"
              ZIndex="1200">
            <Border Padding="20"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="#151310"
                    Stroke="#D8B45F"
                    StrokeThickness="1.5"
                    WidthRequest="330">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="13">
                    <Label Text="เริ่มเอาตัวรอด"
                           TextColor="#D8B45F"
                           FontSize="24"
                           FontAttributes="Bold" />

                    <Label Text="GO OUTSIDE เพื่อออกสำรวจและเจอเหตุการณ์ใหม่"
                           TextColor="#EFE8D8"
                           FontSize="14"
                           LineBreakMode="WordWrap" />

                    <Label Text="ไอเทมในกระเป๋าช่วยปลดล็อกหรือช่วยลดผลเสียของบางตัวเลือก เช่น ไฟฉายในที่มืด เชือกตอนปีน หรือยาตอนบาดเจ็บ"
                           TextColor="#EFE8D8"
                           FontSize="14"
                           LineBreakMode="WordWrap" />

                    <Label Text="REST ใช้ลดความเหนื่อย แต่เวลาเดินและทรัพยากรจะลดลง"
                           TextColor="#EFE8D8"
                           FontSize="14"
                           LineBreakMode="WordWrap" />

                    <Label Text="เกมมี Auto Save และกด SAVE GAME เองได้ในเมนูสามขีด"
                           TextColor="#EFE8D8"
                           FontSize="14"
                           LineBreakMode="WordWrap" />

                    <Button Text="เริ่มเล่น"
                            Clicked="OnTutorialOkClicked"
                            BackgroundColor="#D8B45F"
                            TextColor="#111111"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            Padding="14,12"
                            Margin="0,8,0,0" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
